<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etSearchInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginRight="10dp"
            android:textSize="16sp"
            android:textColorHint="#6FFFFFFF"
            android:textColor="@color/white"
            android:background="@drawable/rounded_corner_background"
            android:hint="Search for shows..."
            android:inputType="text"
            android:padding="10dp" />

        <com.rock.screenshow.views.TVButton
            android:layout_gravity="center"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:id="@+id/btnSearch"
            android:text="Search"
            android:backgroundTint="@color/tv_button_tint"
            android:textColor="@color/tv_button_text_color"
            android:textSize="16sp"
            android:background="@drawable/rounded_corner_background"
            android:padding="10dp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSearchResults"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp" />
</LinearLayout>
